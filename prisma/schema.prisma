model Vacancy {
    id           String        @id @default(uuid())
    title        String
    description  String?       // Add this field
    salaryFrom   Int?          @map("salary_from")  // Add this field
    salaryTo     Int?          @map("salary_to")    // Add this field
    imageUrl      String?
    salary       String?       // Keep or remove this
    isActive     Boolean       @default(true) @map("is_active")
    createdAt    DateTime      @default(now()) @map("created_at")
    updatedAt    DateTime      @updatedAt @map("updated_at")

    applications Application[]
    questions    VacancyQuestion[]

    @@index([isActive])
    @@map("vacancies")
}

enum QuestionType {
  TEXT
  SINGLE_SELECT
  MULTI_SELECT
}

model VacancyQuestion {
  id         String        @id @default(uuid())
  vacancyId  String        @map("vacancy_id")
  question   String        // Question text
  type       QuestionType  @default(TEXT) // Question type
  order      Int           @default(0)
  createdAt  DateTime      @default(now()) @map("created_at")

  vacancy    Vacancy       @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  options    QuestionOption[]

  @@index([vacancyId])
  @@map("vacancy_questions")
}

model QuestionOption {
  id         String          @id @default(uuid())
  questionId String          @map("question_id")
  text       String          // Option text/label
  value      String          // Callback value
  order      Int             @default(0)
  createdAt  DateTime        @default(now()) @map("created_at")

  question   VacancyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_options")
}

model Course {
  id          String      @id @default(uuid())
  title       String
  description String?
   imageUrl      String?
  price       String?     // Simple text field for price  
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  enrollments CourseEnrollment[]
  questions   CourseQuestion[]

  @@index([isActive])
  @@map("courses")
}

model CourseQuestion {
  id         String        @id @default(uuid())
  courseId   String        @map("course_id")
  question   String        // Question text
  type       QuestionType  @default(TEXT) // Question type
  order      Int           @default(0)
  createdAt  DateTime      @default(now()) @map("created_at")

  course     Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  options    CourseQuestionOption[]

  @@index([courseId])
  @@map("course_questions")
}

model CourseQuestionOption {
  id         String         @id @default(uuid())
  questionId String         @map("question_id")
  text       String         // Option text/label
  value      String         // Callback value
  order      Int            @default(0)
  createdAt  DateTime       @default(now()) @map("created_at")

  question   CourseQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("course_question_options")
}

enum EnrollmentStatus {
  NEW
  APPROVED
  REJECTED
}

model CourseEnrollment {
  id           String           @id @default(uuid())
  courseId     String           @map("course_id")
  userId       String           @map("user_id")
  fullName     String           @map("full_name")
  phone        String
  photoFileId  String?          @map("photo_file_id") // Telegram file ID for photo
  answers      Json             @default("{}") // Store all question answers
  status       EnrollmentStatus @default(NEW)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  course       Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([userId])
  @@map("course_enrollments")
}

model ApplicationAnswer {
  id            String           @id @default(uuid())
  applicationId String           @map("application_id")
  fieldKey      String           @map("field_key")
  fieldValue    String           @map("field_value")
  fieldType     AnswerFieldType  @default(TEXT) @map("field_type")
  createdAt     DateTime         @default(now()) @map("created_at")

  application   Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, fieldKey])
  @@index([applicationId])
  @@index([fieldKey])
  @@map("application_answers")
}

model ApplicationFile {
  id              String        @id @default(uuid())
  applicationId   String        @map("application_id")
  type            FileType
  telegramFileId  String        @map("telegram_file_id")
  cloudinaryUrl   String?       @map("cloudinary_url")
  cloudinaryPublicId String?    @map("cloudinary_public_id")
  meta            Json?         @default("{}")
  createdAt       DateTime      @default(now()) @map("created_at")

  application     Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([type])
  @@map("application_files")
}