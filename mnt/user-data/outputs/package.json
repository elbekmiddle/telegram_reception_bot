{
  "name": "telegram-reception-bot",
  "version": "1.0.0",
  "description": "Telegram reception bot for educational center",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "prisma:generate": "dotenv -e .env -- prisma generate",
    "prisma:migrate": "dotenv -e .env -- prisma migrate dev",
    "prisma:studio": "dotenv -e .env -- prisma studio"
  },
  "dependencies": {
    "@grammyjs/conversations": "^1.2.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "axios": "^1.6.2",
    "cloudinary": "^1.41.0",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "grammy": "^1.21.1",
    "ioredis": "^5.3.2",
    "pg": "^8.16.3",
    "pino": "^8.17.1",
    "pino-pretty": "^10.3.1",
    "prom-client": "^15.1.0",
    "sharp": "^0.33.1",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/sharp": "^0.32.0",
    "dotenv-cli": "^7.4.4",
    "prisma": "^7.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}